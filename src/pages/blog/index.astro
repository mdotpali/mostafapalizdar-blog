---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title="Blog" description="Writing about C#, .NET, and software architecture." />
		<style>
			main {
				max-width: 640px;
			}
			h1 {
				font-size: 1.8em;
				margin-bottom: 0.25em;
			}
			.subtitle {
				color: rgb(var(--gray));
				margin-bottom: 2em;
				font-size: 0.95em;
			}
			ul {
				list-style-type: none;
				margin: 0;
				padding: 0;
			}
			ul li {
				border-top: 1px solid rgb(var(--gray-light));
				padding: 1.2em 0;
			}
			ul li:last-child {
				border-bottom: 1px solid rgb(var(--gray-light));
			}
			ul li a {
				display: block;
				text-decoration: none;
			}
			.title {
				margin: 0 0 0.25em 0;
				color: rgb(var(--black));
				font-size: 1.1em;
				font-weight: 600;
			}
			.date {
				margin: 0;
				color: rgb(var(--gray));
				font-size: 0.85em;
			}
			ul li a:hover .title {
				color: rgb(var(--accent));
			}
		</style>
	</head>
	<body>
		<Header />
		<main>
			<h1>Blog</h1>
			<p class="subtitle">C#, .NET, architecture — drawn from what I'm actively building and reading.</p>
			<ul>
				{
					posts.map((post) => (
						<li>
							<a href={`/blog/${post.id}/`}>
								<p class="title">{post.data.title}</p>
								<p class="date">
									<FormattedDate date={post.data.pubDate} />
								</p>
							</a>
						</li>
					))
				}
			</ul>
		</main>
		<Footer />
	</body>
</html>
