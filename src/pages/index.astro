---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<h1>Mostafa Palizdar</h1>
			<p>
				Senior C#/.NET developer based in Munich. I work on complex enterprise systems
				and am working toward a software architect role.
			</p>
			<p>
				I write about C#, .NET, software architecture, and the practical side of
				building systems that last — drawn directly from what I'm reading, building,
				and learning.
			</p>
			<p>
				<a href="/blog">Read the blog →</a>
			</p>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		max-width: 640px;
		box-sizing: border-box;
	}
	h1 {
		font-size: 1.8em;
		margin-bottom: 0.5em;
	}
	p {
		line-height: 1.7;
		margin-bottom: 1.2em;
	}
</style>
